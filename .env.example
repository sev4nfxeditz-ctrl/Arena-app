# ============================================
# Arena Pro — Environment Variables Template
# Copy to .env and fill in your values
# ============================================

# ---- Server ----
PORT=4000
NODE_ENV=development

# ---- Database (PostgreSQL) ----
# Get from Neon (neon.tech) or Supabase
DATABASE_URL=postgresql://user:password@host:5432/arena

# ---- Redis ----
# Get from Upstash (upstash.com)
REDIS_URL=redis://default:password@host:port

# ---- JWT ----
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# ---- CORS ----
# Frontend URL (comma-separated for multiple origins)
CORS_ORIGIN=http://localhost:3000

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ---- GitHub OAuth ----
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ---- Frontend (.env.local) ----
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000
NEXTAUTH_SECRET=your-nextauth-secret
NEXTAUTH_URL=http://localhost:3000
